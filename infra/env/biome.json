{
    "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
    "extends": "//",
    "files": {
        "includes": ["!!**/.svelte-kit", "!!**/generated"]
    },
    "html": {
        "experimentalFullSupportEnabled": true,
        "formatter": {
            "attributePosition": "multiline",
            "enabled": true,
            "bracketSameLine": true,
            "indentScriptAndStyle": true
        },
        "linter": {
            "enabled": true
        },
        "assist": {
            "enabled": true
        }
    },
    "css": {
        "parser": {
            "tailwindDirectives": true
        }
    },
    "overrides": [
        {
            "includes": ["**/*.svelte"],
            "linter": {
                "enabled": true,
                "rules": {
                    "performance": {
                        "noNamespaceImport": "off"
                    },
                    "style": {
                        "useConst": "off",
                        "useImportType": "off"
                    },
                    "correctness": {
                        "noUnusedVariables": "warn",
                        "noUnusedImports": "warn"
                    }
                }
            },
            "css": {
                "formatter": {
                    "indentStyle": "space",
                    "indentWidth": 4,
                    "enabled": true
                },
                "parser": {
                    "tailwindDirectives": true
                }
            }
        }
    ]
}
